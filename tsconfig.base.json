{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@expose/ui-styles": ["./libs/shared/ui/styles/src/index.ts"],
      "@expose/data-access": ["./libs/shared/data-access/src/index.ts"],
      "@expose/photos/data-access": ["./libs/photos/data-access/src/index.ts"],
      "@expose/photos/feature": ["./libs/photos/feature/src/index.ts"],
      "@expose/shell-data-access": ["./libs/shared/shell/data-access/src/index.ts"],
      "@expose/ui/empty-state": ["./libs/shared/ui/components/empty-state/src/index.ts"],
      "@expose/ui/form-fields": ["./libs/shared/ui/components/form-fields/src/index.ts"],
      "@expose/rolls/feature": ["./libs/rolls/feature/src/index.ts"],
      "@expose/sessions/feature": ["./libs/sessions/feature/src/index.ts"],
      "@expose/settings/feature": ["./libs/settings/feature/src/index.ts"],
      "@expose/rolls/data-access": ["./libs/rolls/data-access/src/index.ts"],
      "@expose/sessions/data-access": ["./libs/sessions/data-access/src/index.ts"],
      "@expose/settings/data-access": ["./libs/settings/data-access/src/index.ts"],
      "@expose/util": ["./libs/shared/util/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
