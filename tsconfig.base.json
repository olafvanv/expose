{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@expose/ui": [
        "./libs/ui/src/index.ts"
      ],
      "@expose/feature-sessions": [
        "./libs/features/sessions/src/index.ts"
      ],
      "@expose/feature-rolls": [
        "./libs/features/rolls/src/index.ts"
      ],
      "@expose/feature-settings": [
        "./libs/features/settings/src/index.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
