{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@expose/ui-styles": ["./libs/ui/styles/src/index.ts"],
      "@expose/feature-sessions": ["./libs/features/sessions/src/index.ts"],
      "@expose/feature-rolls": ["./libs/features/rolls/src/index.ts"],
      "@expose/feature-settings": ["./libs/features/settings/src/index.ts"],
      "@expose/data-access": ["./libs/data-access/src/index.ts"],
      "@expose/feature-photo-detail": [
        "./libs/features/photo-detail/src/index.ts"
      ],
      "@expose/feature-photos": ["./libs/features/photos/src/index.ts"],
      "@expose/shell-data-access": ["./libs/shell/data-access/src/index.ts"],
      "@expose/ui-components": ["./libs/ui/components/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
